# ===========================================================================
# Liquidprompt 配置 (v2)
# 基于 v2.2.x 默认值；仅列出非默认项
# 默认值参考: https://liquidprompt.readthedocs.io/en/stable/config.html
# ===========================================================================

# ---------------------------------------------------------------------------
# 显示 — 主机 / 时间 / 数值格式
# ---------------------------------------------------------------------------

# 始终显示主机名（服务器环境需要随时辨别机器）
LP_HOSTNAME_ALWAYS=1

# 始终显示当前时间（便于对照日志时间线）
LP_ENABLE_TIME=1

# 负载/电池/磁盘等数值显示为百分比而非绝对值（默认 0）
LP_DISPLAY_VALUES_AS_PERCENTS=1

# ---------------------------------------------------------------------------
# 版本控制 — 仅保留 Git，禁用不用的 VCS
# ---------------------------------------------------------------------------

LP_ENABLE_SVN=0
LP_ENABLE_HG=0
LP_ENABLE_FOSSIL=0
LP_ENABLE_BZR=0

# ---------------------------------------------------------------------------
# 环境检测 — 容器 / SSH
# ---------------------------------------------------------------------------

# 显示 Docker/LXC/podman 容器名（默认 0）
LP_ENABLE_CONTAINER=1

# SSH 连接时用不同颜色区分主机（默认 0）
LP_ENABLE_SSH_COLORS=1

