{
  "coc.preferences.jumpCommand": "tab drop",
  "coc.preferences.enableMessageDialog": true,
  "codeLens.enable": true,
  "diagnostic.errorSign": "✘",
  "diagnostic.infoSign": "ℹ",
  "diagnostic.hintSign": "➤",
  "outline.autoPreview": true,
  "outline.expandLevel": 0,
  "suggest.minTriggerInputLength": 2,
  "suggest.detailField": "abbr",
  "suggest.snippetIndicator": "🌟",
  "suggest.acceptSuggestionOnCommitCharacter": false,
  "inlayHint.enable": true,
  "pyright.inlayHints.functionReturnTypes": true,
  "pyright.inlayHints.variableTypes": true,
  "pyright.inlayHints.parameterTypes": false,
  "prettier.printWidth": 120,
  "javascript.format.enable": false,
  "typescript.format.enable": false
}
